PORT=3000
NODE_ENV=development
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/vetfinder?schema=public"
REDIS_URL="redis://localhost:6379"
CORS_ORIGINS="http://localhost:3000,http://localhost:5173,http://localhost:8080,http://localhost:5000,http://localhost:53741"
AUTH_RATE_LIMIT_WINDOW_MS="60000"
AUTH_RATE_LIMIT_MAX="20"
JWT_ACCESS_SECRET="change-me"
JWT_REFRESH_SECRET="change-me-too"
# Em produção, troque os secrets acima por valores únicos com 32+ caracteres.
# Nunca reutilize os valores de desenvolvimento ou faça commit do arquivo .env real.
STORAGE_DRIVER="local"
STORAGE_BUCKET="vetfinder-documents"
# Para storage privado S3 compativel (AWS S3, Cloudflare R2 e similares):
S3_ENDPOINT=""
S3_REGION="auto"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_FORCE_PATH_STYLE="false"
PAYMENT_PROVIDER="sandbox-split"
PLATFORM_FEE_RATE="0.03"
